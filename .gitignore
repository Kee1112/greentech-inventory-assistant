# Environment variables - never commit these
.env
.env.local
.env.*.local

# Dependencies
node_modules/
**/node_modules/

# Build outputs
dist/
build/
**/dist/
**/build/

# Database files (runtime data)
*.db
*.sqlite
*.sqlite3
server/tests/test_inventory.db

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# TypeScript cache
*.tsbuildinfo

# SSL certificates (generated locally, never commit)
server/certs/

# Python
__pycache__/
**/__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# Test artifacts
.pytest_cache/
htmlcov/
.coverage
